# runtime/build artifacts
config/.build.env
*.swp
*~

# NEVER commit proprietary firmware (extract from Windows at install time)
*.mbn
*.elf
tcblaunch.exe
firmware/**/*.bin

# SSC sensor data. The sensor registry + config + socinfo ARE committed (the
# generic 8380 reference set; lets the installer work without per-device
# re-extraction). But NEVER commit the DSP firmware ELF blobs (dsp/) or the
# Microsoft-derived, HW-bound secure DB (*.bin) — those are extracted at install.
ssc-data/dsp/
sns-secure-db-seed.bin
sns_secure_database.bin

# slbounce EFI drivers are built from the slbounce project, not committed
config/slbounce/*.efi

# kernel build output / cloned source
*.dtb
Image
zenbook-a14-kernel/
