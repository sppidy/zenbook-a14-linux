+static gboolean
+resolve_platform_profile_paths (PpdDriverPlatformProfile *self)
+{
+  g_autofree char *acpi_path = NULL;
+  g_autofree char *class_dir = NULL;
+  GDir *dir;
+  const char *entry;
+
+  acpi_path = ppd_utils_get_sysfs_path (ACPI_PLATFORM_PROFILE_PATH);
+  if (g_file_test (acpi_path, G_FILE_TEST_EXISTS)) {
+    self->profile_path = g_steal_pointer (&acpi_path);
+    self->choices_path = ppd_utils_get_sysfs_path (ACPI_PLATFORM_PROFILE_CHOICES_PATH);
+    return TRUE;
+  }
+
+  /* Fallback: /sys/class/platform-profile/<name>/{profile,choices}.
+   * Pick the first device — multi-handler systems also expose
+   * /sys/firmware/acpi/platform_profile, so we only land here when
+   * exactly one driver has registered (DT-only path). */
+  class_dir = ppd_utils_get_sysfs_path (CLASS_PLATFORM_PROFILE_DIR);
+  dir = g_dir_open (class_dir, 0, NULL);
+  if (!dir)
+    return FALSE;
+
+  while ((entry = g_dir_read_name (dir)) != NULL) {
+    self->profile_path = g_build_filename (class_dir, entry, "profile", NULL);
+    self->choices_path = g_build_filename (class_dir, entry, "choices", NULL);
+    g_debug ("Using platform_profile class device at %s", self->profile_path);
+    break;
+  }
+  g_dir_close (dir);
+
+  return self->profile_path != NULL;
+}
+
 static PpdProfile
-read_platform_profile (void)
+read_platform_profile (PpdDriverPlatformProfile *self)
 {
-  g_autofree char *platform_profile_path = NULL;
