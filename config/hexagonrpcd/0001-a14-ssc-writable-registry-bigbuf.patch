+ * after the mid (inbufs[0] == { mid, fd }). Honours both the real-write fd
+ * space and ordinary hexagonfs fds.
+ */
+static uint32_t apps_std_fclose_fd(void *data,
+				   const struct fastrpc_io_buffer *inbufs,
+				   struct fastrpc_io_buffer *outbufs)
+{
+	struct apps_std_ctx *ctx = data;
+	const struct {
+		uint32_t mid;
+		uint32_t fd;
+	} *first_in = inbufs[0].p;
+	uint32_t fd = first_in->fd;
+	int ret;
+
+	if (IS_WRITE_FD(fd)) {
+		int slot = fd - WRITE_FD_BASE;
+		if (ctx->write_fds[slot] >= 0) {
+			close(ctx->write_fds[slot]);
+			ctx->write_fds[slot] = -1;
+		}
+		return 0;
+	}
+
+	ret = hexagonfs_close(ctx->fds, fd);
+	if (ret) {
+		fprintf(stderr, "Could not close (fd): %s\n", strerror(-ret));
+		return AEE_EFAILED;
+	}
+
+#ifdef HEXAGONRPC_VERBOSE
+	printf("close_fd(%u)\n", fd);
+#endif
+
+	return 0;
+}
+
+/*
+ * fopen_with_env_fd (msg_id 36): identical inbuf layout to fopen_with_env
+ * (envvar at [1], name at [3], mode at [4]); inbufs[0] is the mid rather than
+ * an empty primitives buffer, and there is one extra output ("len") whose
+ * purpose is unknown -- the ADSP accepts any value. Zero it and reuse the real
+ * open path, which writes the fd into outbufs[0].
+ */
+static uint32_t apps_std_fopen_with_env_fd(void *data,
+					   const struct fastrpc_io_buffer *inbufs,
+					   struct fastrpc_io_buffer *outbufs)
+{
+	struct {
+		uint32_t fd;
+		uint32_t len;
+	} *first_out = outbufs[0].p;
+
+	first_out->len = 0;
+	return apps_std_fopen_with_env(data, inbufs, outbufs);
+}
