index fd28c8c..b68ae0d 100644
--- a/hexagonrpcd/hexagonfs_mapped.c
+++ b/hexagonrpcd/hexagonfs_mapped.c
@@ -351,3 +351,27 @@ struct hexagonfs_file_ops hexagonfs_mapped_sysfs_ops = {
 	.seek = mapped_seek,
 	.stat = mapped_sysfs_stat,
 };
+
+/*
+ * Return the underlying host file descriptor backing a mapped fd, or -1 if the
+ * fd is not host-backed (a virtual node, or an "empty" mapped_or_empty
+ * placeholder with no host file). The write path needs this to resolve the host
+ * path via /proc/self/fd/<host fd>; casting fd->data (a struct mapped_ctx *)
+ * straight to an int yields the truncated pointer, not a descriptor.
+ */
+int hexagonfs_mapped_host_fd(struct hexagonfs_fd *fd)
+{
+	struct mapped_ctx *ctx;
+
+	if (fd == NULL
+	 || (fd->ops != &hexagonfs_mapped_ops
+	  && fd->ops != &hexagonfs_mapped_or_empty_ops
+	  && fd->ops != &hexagonfs_mapped_sysfs_ops))
+		return -1;
+
+	ctx = fd->data;
+	if (ctx == NULL)
+		return -1;
+
+	return ctx->fd;
+}
