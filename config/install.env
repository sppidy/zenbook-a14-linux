# Per-machine install configuration. Edit before running install.sh.
# Values below are EXAMPLES from the reference install — change them for yours.

# --- root filesystem ---
# Find with:  findmnt -no UUID /
ROOT_UUID="b0371b1f-cde9-4667-86d3-765ad7e08afc"

# --- where to find the proprietary firmware to extract ---
# The extractor searches ALL of these by filename (first match wins). Mix freely:
#   * an extracted ASUS/Qualcomm OFFICIAL DRIVER download folder for the A14
#   * an already-extracted Qualcomm BSP dump
#   * a mounted Windows partition (read-only)
FW_SOURCES=(
	# "/path/to/asus-official-drivers"   # ASUS support .zip(s) extracted
	# "/path/to/Win-Drivers"             # a BSP dump
	# "/mnt/windows"                     # mounted Windows C: (read-only)
)
# Convenience single-dir knobs (each appended to FW_SOURCES if set):
DRIVER_DIR=""                          # extracted official ASUS/Qualcomm driver folder
BSP_DIR=""                             # extracted BSP dump
WINDOWS_MOUNT=""                       # mounted Windows partition (uses its DriverStore)

# --- kernel source ---
KERNEL_REPO="https://github.com/sppidy/linux.git"
KERNEL_BRANCH="a14/jg-qcom-7.1-rc-6"   # the published daily-driver branch
KERNEL_SRC="$HOME/zenbook-a14-kernel"  # clone/build location
KERNEL_RELEASE=""                      # auto-detected from the build if empty
JOBS="$(nproc)"

# --- boot ---
ESP="/boot/efi"
MACHINE_ID=""                          # empty => use /etc/machine-id
# Kernel cmdline for the EL2 entry. Keep the qcom/EL2-specific flags.
KERNEL_CMDLINE="ro clk_ignore_unused pd_ignore_unused cma=128M efi=noruntime quiet splash console=tty0 id_aa64mmfr0.ecv=1 arm-smmu.disable_bypass=0 iommu.strict=1 mem_sleep_default=s2idle"

# --- tcblaunch (Microsoft DRTM binary, extracted from Windows) ---
# slbounce only bounces a SPECIFIC build. The known-good one for this platform:
TCBLAUNCH_VERSION="26100.6584"
# Optional: a Windows 11 24H2 (build 26100.6584) ISO or install.wim/.esd to
# auto-extract tcblaunch.exe from (scripts/extract-tcblaunch.sh). Get the exact
# build via uupdump.net — see docs/tcblaunch.md.
TCBLAUNCH_ISO=""                       # e.g. /path/to/Win11_24H2_26100.6584_arm64.iso
